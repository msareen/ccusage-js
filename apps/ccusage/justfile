# Recipes for the published `ccusage` npm package. Run from the repo root as
# `just ccusage::<recipe>`, or from this directory as `just <recipe>`.

[private]
default:
    @just --list

# Build the package bundle with tsdown. Delegated to the package script because
# npm `prepack` and `pkg-pr-new publish` invoke `bun run build` by name.
build:
    bun run build

# Type-check the package
typecheck:
    bun run tsc --noEmit
